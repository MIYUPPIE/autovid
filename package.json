{
  "name": "griotvid",
  "version": "1.0.0",
  "description": "GriotVid — AI video studio: xAI scripting + free stock footage + neural voiceover (incl. Yoruba/Igbo/Hausa) + FFmpeg editing engine",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "worker": "node src/worker.js",
    "dev": "node --watch src/server.js",
    "check": "node src/check-env.js",
    "test": "node --test test/gate.test.js test/project.test.js",
    "eval": "node test/eval.js",
    "eval:queue": "node test/queue.smoke.js",
    "eval:yarn": "node test/yarn.smoke.js",
    "eval:render": "node test/render.smoke.js",
    "eval:edit": "node test/edit.smoke.js",
    "eval:beats": "node test/beats.smoke.js",
    "eval:cards": "node test/cards.smoke.js",
    "eval:transitions": "node test/transitions.smoke.js",
    "eval:transcribe": "node test/transcribe.smoke.js",
    "eval:youtube": "node test/youtube.smoke.js"
  },
  "dependencies": {
    "bullmq": "^5.78.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "nanoid": "^5.0.7",
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=18"
  }
}
