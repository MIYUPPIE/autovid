# ---- GriotVid environment ----
# Copy to .env and fill in. All three keys you said you already have.

XAI_API_KEY=your_xai_key_here
PEXELS_API_KEY=your_pexels_key_here
PIXABAY_API_KEY=your_pixabay_key_here

# YouTube footage source — no API key. Needs the `yt-dlp` binary on PATH
# (pip install yt-dlp). Only a short opening section of each video is pulled, so a
# 30-minute source is a ~2MB download. The "Use YouTube footage" toggle and the
# editor's YouTube gallery tab appear automatically when yt-dlp is detected.
# YTDLP_BIN=yt-dlp
# YOUTUBE_SECTION_SECONDS=30
# YOUTUBE_DOWNLOAD_TIMEOUT_MS=90000
# YOUTUBE_SEARCH_TIMEOUT_MS=25000

# Automatic background music (free royalty-free library).
# Get a client id at https://devportal.jamendo.com  (2-minute signup).
JAMENDO_CLIENT_ID=your_jamendo_client_id_here

# xAI model used for scripting / scene planning
XAI_MODEL=grok-4-latest

# LLM provider for scriptwriting/planning: xai (default) | openrouter | claude-code
LLM_PROVIDER=xai
# OpenRouter (one key → Claude/GPT/Llama/DeepSeek/etc). Used when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Local Claude Code CLI binary. Used when LLM_PROVIDER=claude-code.
CLAUDE_BIN=claude

# Server
PORT=3000

# ---- Job queue (renders/dubs/shorts) ----
# Leave REDIS_URL blank for the in-memory backend (single box; a render is lost
# if the process restarts mid-job). Set it to a Redis instance to use the
# BullMQ-backed queue: jobs persist in Redis and survive a restart (a worker
# re-runs an interrupted render). Install Redis: `sudo apt install -y redis-server`.
REDIS_URL=
# REDIS_URL=redis://127.0.0.1:6379
# Queue name + key prefix (lets several apps share one Redis).
QUEUE_NAME=griotvid
QUEUE_PREFIX=griotvid
# Jobs one worker runs at once. Renders are GPU/CPU-heavy — keep 1 on a single
# box; raise only with cores to spare.
WORKER_CONCURRENCY=1
# With Redis on, `npm start` also runs a worker inside the web process by
# default (single-box). Set to 0 to make the web server enqueue-only and run a
# dedicated `npm run worker` process (scale-out / restart isolation).
WORKER_INLINE=1
# How often the job status SSE/poll re-reads progress (ms).
JOB_POLL_MS=400

# Public origin shared links point at. Leave blank to derive from the request
# host (localhost/LAN). Set this to your tunnel/domain so shared links resolve
# for other people, e.g. https://autovid.example.com
SHARE_BASE_URL=

# Voice engine: edge-tts (default). Must be installed (see README).
TTS_ENGINE=edge-tts

# YarnGPT — hosted Nigerian-language TTS for Yoruba / Igbo / Hausa voices.
# Get a key at https://yarngpt.ai. Required only if you use those voices.
YARN_API_KEY=your_yarngpt_key_here
# YarnGPT is slow per call but serves ~4 requests in parallel, so the narration
# is split into ~YARN_CONCURRENCY sentence-aligned chunks and run in one wave.
# Don't raise concurrency past ~4 — the API throttles hard above that.
YARN_CONCURRENCY=4
YARN_MIN_CHUNK_CHARS=100
YARN_TIMEOUT_MS=180000

# Video encoder: 'auto' picks h264_nvenc (GPU) when present, else libx264.
VIDEO_ENCODER=auto

# Pacing: one scene per N seconds of narration, capped. Fewer = less choppy/faster.
SCENE_SECONDS=10
MAX_SCENES=8

# Concurrency / limits
MAX_CLIPS=12
DOWNLOAD_TIMEOUT_MS=45000
