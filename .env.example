# ---- AutoVid environment ----
# Copy to .env and fill in. All three keys you said you already have.

XAI_API_KEY=your_xai_key_here
PEXELS_API_KEY=your_pexels_key_here
PIXABAY_API_KEY=your_pixabay_key_here

# Automatic background music (free royalty-free library).
# Get a client id at https://devportal.jamendo.com  (2-minute signup).
JAMENDO_CLIENT_ID=your_jamendo_client_id_here

# xAI model used for scripting / scene planning
XAI_MODEL=grok-4-latest

# LLM provider for scriptwriting/planning: xai (default) | openrouter | claude-code
LLM_PROVIDER=xai
# OpenRouter (one key → Claude/GPT/Llama/DeepSeek/etc). Used when LLM_PROVIDER=openrouter.
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Local Claude Code CLI binary. Used when LLM_PROVIDER=claude-code.
CLAUDE_BIN=claude

# Server
PORT=3000

# Voice engine: edge-tts (default). Must be installed (see README).
TTS_ENGINE=edge-tts

# Python (with torch + transformers) for local MMS-TTS native-language voices
# (Yoruba/Igbo/Hausa). Defaults to the tf_gpu conda env.
MMS_PYTHON=/home/okhub/anaconda3/envs/tf_gpu/bin/python

# MMS voice steadiness. Lower than the 0.667 default = cleaner/steadier delivery,
# higher = more expressive but more variable. Tune if native voices sound off.
MMS_NOISE_SCALE=0.6

# Video encoder: 'auto' picks h264_nvenc (GPU) when present, else libx264.
VIDEO_ENCODER=auto

# Pacing: one scene per N seconds of narration, capped. Fewer = less choppy/faster.
SCENE_SECONDS=10
MAX_SCENES=8

# Concurrency / limits
MAX_CLIPS=12
DOWNLOAD_TIMEOUT_MS=45000
